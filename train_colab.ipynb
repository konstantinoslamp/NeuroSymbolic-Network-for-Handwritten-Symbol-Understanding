   "source": [
    "# Neurosymbolic MVP — CNN Training\n",
    "Trains the custom CNN (built from scratch with NumPy) on MNIST digit classification.\n",
    "\n",
    "**Architecture:** Conv2D(1→8, 3×3) → ReLU → MaxPool(2×2) → Flatten → Dense(1352→128) → ReLU → Dense(128→14) → Softmax"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Clone the repo"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import os\n",
    "\n",
    "REPO_URL = \"https://github.com/konstantinoslamp/neurosymbolic_mvp.git\"  # update if needed\n",
    "REPO_DIR = \"/content/neurosymbolic_mvp\"\n",
    "\n",
    "if not os.path.exists(REPO_DIR):\n",
    "    !git clone $REPO_URL $REPO_DIR\n",
    "else:\n",
    "    print(\"Repo already cloned — pulling latest changes\")\n",
    "    !git -C $REPO_DIR pull\n",
    "\n",
    "%cd $REPO_DIR\n",
    "print(\"Working directory:\", os.getcwd())"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Install dependencies"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "!pip install -q tqdm numpy"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Download MNIST"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import urllib.request\n",
    "import numpy as np\n",
    "\n",
    "MNIST_PATH = \"/content/neurosymbolic_mvp/src/neural/mnist.npz\"\n",
    "\n",
    "if not os.path.exists(MNIST_PATH):\n",
    "    print(\"Downloading MNIST...\")\n",
    "    url = \"https://storage.googleapis.com/tensorflow/tf-keras-datasets/mnist.npz\"\n",
    "    urllib.request.urlretrieve(url, MNIST_PATH)\n",
    "    print(\"Done.\")\n",
    "else:\n",
    "    print(\"MNIST already present.\")\n",
    "\n",
    "data = np.load(MNIST_PATH)\n",
    "x_train_raw, y_train = data['x_train'], data['y_train']\n",
    "x_test_raw,  y_test  = data['x_test'],  data['y_test']\n",
    "\n",
    "# Normalise and add channel dim\n",
    "x_train = (x_train_raw.astype(np.float32) / 255.0)[:, None, :, :]  # (60000, 1, 28, 28)\n",
    "x_test  = (x_test_raw.astype(np.float32)  / 255.0)[:, None, :, :]  # (10000, 1, 28, 28)\n",
    "\n",
    "print(f\"Train: {x_train.shape}, Test: {x_test.shape}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Load the CNN"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sys\n",
    "sys.path.insert(0, \"/content/neurosymbolic_mvp/src/neural\")\n",
    "\n",
    "from model import CNN\n",
    "\n",
    "model = CNN()\n",
    "print(\"CNN initialised (14 output classes)\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Training"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from tqdm.notebook import tqdm\n",
    "\n",
    "# ── Hyperparameters ────────────────────────────────────────────────────────────\n",
    "EPOCHS        = 5\n",
    "BATCH_SIZE    = 64\n",
    "LEARNING_RATE = 0.01\n",
    "# ──────────────────────────────────────────────────────────────────────────────\n",
    "\n",
    "batches_per_epoch = len(x_train) // BATCH_SIZE\n",
    "history = {\"train_loss\": [], \"test_acc\": []}\n",
    "\n",
    "epoch_bar = tqdm(range(EPOCHS), desc=\"Epochs\", unit=\"epoch\")\n",
    "\n",
    "for epoch in epoch_bar:\n",
    "    epoch_loss = 0.0\n",
    "\n",
    "    # Shuffle training data each epoch\n",
    "    perm = np.random.permutation(len(x_train))\n",
    "    x_shuf, y_shuf = x_train[perm], y_train[perm]\n",
    "\n",
    "    batch_bar = tqdm(\n",
    "        range(batches_per_epoch),\n",
    "        desc=f\"  Epoch {epoch+1}/{EPOCHS}\",\n",
    "        unit=\"batch\",\n",
    "        leave=False,\n",
    "    )\n",
    "\n",
    "    for b in batch_bar:\n",
    "        x_batch = x_shuf[b * BATCH_SIZE : (b + 1) * BATCH_SIZE]\n",
    "        y_batch = y_shuf[b * BATCH_SIZE : (b + 1) * BATCH_SIZE]\n",
    "\n",
    "        logits = model.forward(x_batch)\n",
    "        loss   = model.compute_loss(logits, y_batch)\n",
    "        model.backward()\n",
    "        model.update_weights(LEARNING_RATE)\n",
    "\n",
    "        epoch_loss += loss\n",
    "        batch_bar.set_postfix(loss=f\"{loss:.4f}\")\n",
    "\n",
    "    # ── Evaluate on test set ──────────────────────────────────────────────────\n",
    "    correct, total = 0, 0\n",
    "    for i in range(len(x_test) // BATCH_SIZE):\n",
    "        xb = x_test[i * BATCH_SIZE : (i + 1) * BATCH_SIZE]\n",
    "        yb = y_test[i * BATCH_SIZE : (i + 1) * BATCH_SIZE]\n",
    "        correct += np.sum(model.predict(xb) == yb)\n",
    "        total   += len(yb)\n",
    "    acc = correct / total * 100\n",
    "\n",
    "    avg_loss = epoch_loss / batches_per_epoch\n",
    "    history[\"train_loss\"].append(avg_loss)\n",
    "    history[\"test_acc\"].append(acc)\n",
    "\n",
    "    epoch_bar.set_postfix(avg_loss=f\"{avg_loss:.4f}\", test_acc=f\"{acc:.2f}%\")\n",
    "\n",
    "print(\"\\nTraining complete!\")\n",
    "for i, (l, a) in enumerate(zip(history['train_loss'], history['test_acc']), 1):\n",
    "    print(f\"  Epoch {i}: loss={l:.4f}  test_acc={a:.2f}%\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. Plot loss & accuracy"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import matplotlib.pyplot as plt\n",
    "\n",
    "epochs_x = range(1, EPOCHS + 1)\n",
    "fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(12, 4))\n",
    "\n",
    "ax1.plot(epochs_x, history['train_loss'], marker='o', color='steelblue')\n",
    "ax1.set_title('Training Loss')\n",
    "ax1.set_xlabel('Epoch')\n",
    "ax1.set_ylabel('Loss')\n",
    "ax1.grid(True)\n",
    "\n",
    "ax2.plot(epochs_x, history['test_acc'], marker='o', color='darkorange')\n",
    "ax2.set_title('Test Accuracy')\n",
    "ax2.set_xlabel('Epoch')\n",
    "ax2.set_ylabel('Accuracy (%)')\n",
    "ax2.grid(True)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('training_curves.png', dpi=150)\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 7. Save model weights"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "save_path = \"/content/neurosymbolic_mvp/trained_cnn_model.pkl\"\n",
    "model.save_weights(save_path)\n",
    "print(f\"Model saved to: {save_path}\")\n",
    "\n",
    "# Optional: download to your local machine\n",
    "from google.colab import files\n",
    "files.download(save_path)"
   ]
  }
 ]
}"
